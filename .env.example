# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Domain & URL Configuration (US Dental Directory)
NEXT_PUBLIC_DOMAIN="appointpanda.com"
NEXT_PUBLIC_BASE_URL="https://www.appointpanda.com"
NEXT_PUBLIC_DEFAULT_COUNTRY="us"
NEXT_PUBLIC_DEFAULT_CITY="los-angeles"
NEXT_PUBLIC_DEFAULT_STATE="ca"

# Prerendering (optional - for SEO)
# Get your token from https://prerender.io
PRERENDER_TOKEN=""

# WhatsApp Webhook (required for production security)
# Get your app secret from Facebook Developer Portal
WHATSAPP_APP_SECRET=""

# Stripe (optional - for payments)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Google OAuth (optional)
# Get credentials from Google Cloud Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
